# Data provider mode: mock, tradier, or polygon
DATA_PROVIDER=mock

# Optional provider keys. Keep real tokens in .env, never in browser code.
TRADIER_TOKEN=
TRADIER_BASE_URL=https://api.tradier.com
POLYGON_API_KEY=

# Comma-separated underlyings used by the dashboard quote strip.
WATCHLIST=SMH,NVDA,AMD,MU,AVGO,INTC,QQQ,SPY

# Optional manual overrides for licensed/paid structure indices.
# Use these until you connect Cboe Global Indices Feed or another licensed source.
VIXEQ_VALUE=
VIX_VALUE=
COR1M_VALUE=
HVL_VALUE=7495
