# 数据源模式：mock、tradier、polygon 或 massive
DATA_PROVIDER=mock

# 数据源密钥。真实 key 只放在 .env，不要写进浏览器代码。
TRADIER_TOKEN=
TRADIER_BASE_URL=https://api.tradier.com
POLYGON_API_KEY=
MASSIVE_API_KEY=

# 表盘报价条使用的标的列表。
WATCHLIST=SMH,NVDA,AMD,MU,AVGO,INTC,QQQ,SPY

# 授权指数和结构指标的手动覆盖。
# 在接入 Cboe、期权链或 Gamma 模型前，可以先用这些字段让表盘完整显示。
VIXEQ_VALUE=
VIX_VALUE=
COR1M_VALUE=
SPX_VALUE=
HVL_VALUE=7495
SENTIMENT_VALUE=
